<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.study.htmlCoding.mapper.TestCaseMapper">

    <select id="getMaxTestCaseId" resultType="Long">
        select max(test_case_id) from tb_test_case
    </select>

    <update id="deleteTestCase">
        update tb_test_case set deleted = 0 where test_case_id = #{testCaseId}
    </update>

</mapper>